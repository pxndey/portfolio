{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "scripts": {
    "generate:data": "bun run scripts/generate-portfolio-data.ts && bun run scripts/generate-themes.ts",
    "dev": "bun run generate:data && bun --hot src/index.tsx",
    "build": "bun run generate:data && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.tsx"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.6.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
